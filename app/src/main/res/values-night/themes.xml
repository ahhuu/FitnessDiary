<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FitnessDiary" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark mode color overrides -->
        <item name="colorPrimary">@color/fitnessdiary_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">#1B3A2A</item>
        <item name="colorOnPrimaryContainer">#A0D9B0</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="colorSurfaceVariant">#2C2C2C</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>

        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#121212</item>
        <item name="android:windowBackground">#121212</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.FitnessDiary</item>
    </style>
</resources>
