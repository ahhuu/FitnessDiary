<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：3D 浮雕深层阴影面 -->
    <item android:left="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <solid android:color="#40000000" />
        </shape>
    </item>

    <!-- 中间层：左上角斜向漏出的高光线（深色模式弱化） -->
    <item android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- 最表层：主面板，深色渐变 -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <gradient
                android:angle="315"
                android:startColor="#2C2C2C"
                android:endColor="#252525"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
