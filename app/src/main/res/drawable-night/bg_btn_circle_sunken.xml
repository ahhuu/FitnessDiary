<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 下层：右下亮色反光线（深色模式弱化） -->
    <item android:left="1dp" android:top="1dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF"/>
        </shape>
    </item>
    <!-- 中层：左上暗色内阴影线 -->
    <item android:left="0dp" android:top="0dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="#40000000"/>
        </shape>
    </item>
    <!-- 表层：下凹区域填充底色（深色） -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="#2A2A2A"/>
        </shape>
    </item>
</layer-list>
