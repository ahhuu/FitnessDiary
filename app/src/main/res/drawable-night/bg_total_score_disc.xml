<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下深色投影（外盘阴影） -->
    <item
        android:left="1.5dp"
        android:top="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#40000000"/>
        </shape>
    </item>

    <!-- 中层：左上半透明白高光 -->
    <item
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF"/>
        </shape>
    </item>

    <!-- 顶层面：底盘主体，深色渐变 -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#2C2C2C"
                android:endColor="#282828"
                android:angle="315"
                android:type="linear"/>
            <stroke
                android:width="1dp"
                android:color="#404040"/>
        </shape>
    </item>
</layer-list>
