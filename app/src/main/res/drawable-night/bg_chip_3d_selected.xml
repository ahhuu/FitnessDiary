<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#402E6BB3" />
        </shape>
    </item>
    <item android:left="1.2dp" android:top="1.2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>
    <item android:left="1.2dp" android:top="1.2dp" android:right="1.2dp" android:bottom="1.2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10.5dp" />
            <gradient android:startColor="#2A3645" android:endColor="#24303E" android:angle="315" android:type="linear" />
        </shape>
    </item>
</layer-list>
