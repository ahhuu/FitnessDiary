<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <ViewFlipper
        android:id="@+id/view_flipper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:inAnimation="@anim/anim_fade_in_short"
        android:outAnimation="@anim/anim_fade_out_short">

        <!-- Stage 1: Landing (封面页) -->
        <LinearLayout
            android:id="@+id/layout_landing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:background="@color/background"
            android:padding="32dp">

            <!-- Logo 3D 徽章托盘承托容器 -->
            <LinearLayout
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:background="@drawable/bg_card_3d_normal"
                android:gravity="center"
                android:padding="28dp"
                android:layout_marginBottom="40dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img_welcome_hero"
                    android:scaleType="centerInside"
                    android:importantForAccessibility="no" />
            </LinearLayout>

            <!-- 增加字间距和字重的秀雅辅助语 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开启您的健康之旅"
                android:textSize="16sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="48dp" />

            <!-- 主按钮：3D 深褐色立体键 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_to_setup"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="立即定制"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_3d_primary"
                app:backgroundTint="@null"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <!-- 辅助按钮：3D 奶油白色立体键 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_skip"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="以后再说"
                android:textSize="16sp"
                android:background="@drawable/bg_btn_3d_secondary"
                app:backgroundTint="@null"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Stage 2: Setup (表单页) -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageButton
                    android:id="@+id/btn_back_to_landing"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_arrow_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/text_primary"
                    android:layout_marginBottom="16dp"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="完善资料"
                    android:textSize="28sp"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="24dp" />

                <!-- 卡片一：基本信息 (3D 拟物卡片) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_3d_normal"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 昵称内凹输入框外壳 -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_input_sunken"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:boxBackgroundColor="@android:color/transparent"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:hint="@string/hint_nickname">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_nickname"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:textSize="15sp"
                                    android:textColor="@color/text_primary"
                                    android:inputType="textPersonName|textNoSuggestions" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="12dp"
                            android:layout_height="match_parent" />

                        <!-- 年龄内凹输入框外壳 -->
                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="56dp"
                            android:background="@drawable/bg_input_sunken"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                app:boxStrokeWidth="0dp"
                                app:boxStrokeWidthFocused="0dp"
                                app:boxBackgroundColor="@android:color/transparent"
                                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                                android:hint="@string/hint_age">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_age"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/transparent"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:textSize="15sp"
                                    android:textColor="@color/text_primary"
                                    android:inputType="number" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="性别"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="12dp" />

                    <!-- 3D 拟物单选按钮组 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chip_female"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="10dp"
                            android:textSize="14sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/gender_female" />

                        <TextView
                            android:id="@+id/chip_male"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="20dp"
                            android:paddingVertical="10dp"
                            android:textSize="14sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/gender_male" />
                    </LinearLayout>

                </LinearLayout>

                <!-- 卡片二：身体指标 (3D 拟物卡片) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_3d_normal"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:layout_marginBottom="20dp">

                    <!-- 身高内凹输入框外壳 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_sunken"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp"
                            app:boxBackgroundColor="@android:color/transparent"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:hint="@string/hint_height">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_height"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                android:inputType="numberDecimal"
                                android:digits="0123456789." />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="16dp"
                        android:layout_height="match_parent" />

                    <!-- 体重内凹输入框外壳 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_sunken"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@android:color/transparent"
                            app:boxStrokeWidth="0dp"
                            app:boxStrokeWidthFocused="0dp"
                            app:boxBackgroundColor="@android:color/transparent"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:hint="@string/hint_weight">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_weight"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/transparent"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                android:inputType="numberDecimal"
                                android:digits="0123456789." />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                </LinearLayout>

                <!-- 卡片三：目标与活动水平 (3D 拟物卡片) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_3d_normal"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginBottom="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="健身目标"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- 3D 目标单选组合 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="18dp">

                        <TextView
                            android:id="@+id/chip_lose_fat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="10dp"
                            android:textSize="14sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/goal_lose_fat" />

                        <TextView
                            android:id="@+id/chip_gain_muscle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="12dp"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="10dp"
                            android:textSize="14sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/goal_gain_muscle" />

                        <TextView
                            android:id="@+id/chip_maintain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="18dp"
                            android:paddingVertical="10dp"
                            android:textSize="14sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/goal_maintain" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="活动水平"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- 3D 活动水平单选组合 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/chip_sedentary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:textSize="13sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="久坐" />

                        <TextView
                            android:id="@+id/chip_light"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:textSize="13sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="轻度活动" />

                        <TextView
                            android:id="@+id/chip_moderate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="10dp"
                            android:textSize="13sp"
                            android:textColor="@color/color_chip_text_3d"
                            android:background="@drawable/selector_chip_3d"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:fontFamily="sans-serif-medium"
                            android:text="中度活动" />
                    </LinearLayout>

                </LinearLayout>

                <!-- 卡路里预览 -->
                <TextView
                    android:id="@+id/tv_calorie_preview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="预计每日目标：2000 千卡"
                    android:textSize="16sp"
                    android:textColor="@color/primary"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone"
                    android:layout_marginBottom="24dp"
                    android:layout_gravity="center_horizontal" />

                <!-- 开始按钮 (套用 3D 拟物背景) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_start"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="开启探索"
                    android:textSize="16sp"
                    android:background="@drawable/bg_btn_3d_primary"
                    app:backgroundTint="@null"
                    android:textColor="@color/white" />

            </LinearLayout>
        </ScrollView>
    </ViewFlipper>
</ScrollView>
