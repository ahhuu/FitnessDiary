<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- 顶部拖拽条 -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_drag_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="健康周报分析"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/black"
        android:layout_marginBottom="16dp" />

    <!-- 顶部切换器 -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/toggle_date_range"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        app:singleSelection="true"
        app:checkedButton="@id/btn_week"
        android:layout_marginBottom="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本周"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="本月"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp">

            <!-- 模块 1：训练看板 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fitnessdiary_surface_variant"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💪 训练强度"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView
                            android:id="@+id/tv_training_days_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0天"
                            android:textColor="@color/fitnessdiary_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/progress_training_days"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="12dp"
                        android:progressDrawable="@drawable/progress_rounded_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 模块 2：饮食仪表盘 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fitnessdiary_surface_variant"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <!-- 热量文字信息 (左侧) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="24dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🥗 饮食热量"
                            android:textStyle="bold"
                            android:textColor="@color/black" />
                        <TextView
                            android:id="@+id/tv_calories_intake_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="摄入: 0"
                            android:layout_marginTop="4dp"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_calories_target_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="目标: 2000"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <!-- 圆形进度条区域 (右侧) -->
                    <FrameLayout
                        android:layout_width="80dp"
                        android:layout_height="80dp">
                        <ProgressBar
                            android:id="@+id/progress_calories_circle"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="70"
                            android:progressDrawable="@drawable/bg_circle_progress" />
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:id="@+id/tv_calories_percent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="70%"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 模块 3：体重 & BMI -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fitnessdiary_surface_variant"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚖️ 体重分析"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="14sp" />
                    
                    <TextView
                        android:id="@+id/tv_weight_bmi_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="65kg (Normal)"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 模块 4：睡眠看板 (NEW) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/fitnessdiary_surface_variant"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌙 睡眠质量"
                            android:textStyle="bold"
                            android:textColor="@color/black"
                            android:textSize="14sp" />
                        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                        <TextView
                            android:id="@+id/tv_sleep_avg_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 小时"
                            android:textColor="@color/fitnessdiary_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_sleep_quality_avg_value"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="平均质量: --"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 核心：智能分析区域 -->
            <FrameLayout
                android:id="@+id/container_analysis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp">

                <!-- 状态 A: 按钮 -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_generate_analysis"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="🔍 生成健康分析"
                    app:cornerRadius="12dp"
                    android:textSize="16sp"
                    android:visibility="visible" />

                <!-- 状态 B: 结果卡片 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_analysis_result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#1A009688"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 智能分析建议"
                            android:textStyle="bold"
                            android:textColor="#009688"
                            android:textSize="13sp" />
                        <TextView
                            android:id="@+id/tv_analysis_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="正在分析您的运动与健康数据..."
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </FrameLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
