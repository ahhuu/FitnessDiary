<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_habit"
    android:layout_width="0dp"
    android:layout_height="190dp"
    android:layout_weight="1"
    android:layout_marginEnd="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/fitnessdiary_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_habit_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_hero_calendar"
                app:tint="@color/fitnessdiary_primary" />

            <TextView
                android:id="@+id/tv_habit_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="习惯"
                android:textColor="@color/text_primary"
                android:textSize="17sp" />

            <ImageButton
                android:id="@+id/btn_add_habit"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@android:color/transparent"
                android:contentDescription="添加"
                android:src="@drawable/ic_add"
                app:tint="@color/fitnessdiary_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_habit_update"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="暂无更新"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_habit_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="--"
            android:textColor="@color/fitnessdiary_primary"
            android:textSize="24sp" />

        <TextView
            android:id="@+id/tv_habit_summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="暂无记录"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>