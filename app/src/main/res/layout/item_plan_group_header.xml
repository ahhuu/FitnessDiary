<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="@color/plan_blue_header_collapsed"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="#DDE5EC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp">

        <View
            android:id="@+id/view_category_indicator"
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_category_indicator" />

        <ImageView
            android:id="@+id/iv_header_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginEnd="8dp"
            android:alpha="0.9"
            android:contentDescription="部位图标"
            android:src="@drawable/ic_muscle_chest"
            app:tint="@color/plan_blue_primary" />

        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="胸部训练"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_count_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/plan_blue_container"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tv_plan_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="3 个动作"
                android:textColor="@color/plan_blue_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:id="@+id/iv_expand_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:alpha="0.65"
            android:src="@drawable/ic_arrow_right"
            app:tint="@color/text_secondary" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
