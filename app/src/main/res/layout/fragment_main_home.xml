<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ViewPager2 核心页面滑动容器 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 全局新成就解锁/消息卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_global_notice"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/fitnessdiary_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingVertical="12dp">

            <TextView
                android:id="@+id/tv_global_notice_emoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_global_notice_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新成就解锁"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_global_notice_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="点击查看详情"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_global_notice_action"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="8dp"
                android:text="查看"
                android:textColor="@color/ai_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btn_global_notice_close"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="4dp"
                android:text="关闭"
                android:textColor="@color/text_hint"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 底部导航分割线 (已隐藏) -->
    <View
        android:id="@+id/bottom_nav_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_custom" />

    <!-- 方案 B：自定义温润胶囊底部导航栏 (悬浮 3D 拟物胶囊) -->
    <LinearLayout
        android:id="@+id/bottom_nav_custom"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_bottom_nav_3d"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 1. 记录 Tab -->
        <FrameLayout
            android:id="@+id/tab_checkin"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/tab_checkin_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:id="@+id/tab_checkin_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/selector_nav_icon_checkin"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tab_checkin_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="记录"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- 2. 计划 Tab -->
        <FrameLayout
            android:id="@+id/tab_plan"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/tab_plan_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:id="@+id/tab_plan_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/selector_nav_icon_plan"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tab_plan_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="计划"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- 3. 饮食 Tab -->
        <FrameLayout
            android:id="@+id/tab_diet"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/tab_diet_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:id="@+id/tab_diet_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/selector_nav_icon_diet"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tab_diet_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="饮食"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- 4. AI 私教 Tab -->
        <FrameLayout
            android:id="@+id/tab_ai"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/tab_ai_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:id="@+id/tab_ai_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/selector_nav_icon_ai"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tab_ai_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="AI私教"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- 5. 我的 Tab -->
        <FrameLayout
            android:id="@+id/tab_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless">

            <LinearLayout
                android:id="@+id/tab_profile_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="14dp"
                android:paddingVertical="5dp">

                <ImageView
                    android:id="@+id/tab_profile_icon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/selector_nav_icon_profile"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tab_profile_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="我的"
                    android:textColor="@color/text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
