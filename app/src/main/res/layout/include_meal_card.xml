<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_meal_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@android:color/transparent"
    app:cardCornerRadius="24dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:outlineSpotShadowColor="#1A4E3F35"
    android:outlineAmbientShadowColor="#1A4E3F35">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_3d_meal"
        android:padding="16dp">

        <!-- 餐点名称 -->
        <TextView
            android:id="@+id/tv_meal_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="早餐"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 添加按钮 (右上角) -->
        <ImageButton
            android:id="@+id/btn_add_food"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/date_circle_background_diet"
            android:src="@android:drawable/ic_input_add"
            android:tint="@color/diet_primary"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:contentDescription="添加食物"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
            
        <!-- 食物摘要列表 (中间区域，自适应高度) -->
        <TextView
            android:id="@+id/tv_food_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:text="暂无记录"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="top|start"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_meal_name"
            app:layout_constraintBottom_toTopOf="@id/tv_meal_calories" />

        <!-- 热量总和 (左下角) -->
        <TextView
            android:id="@+id/tv_meal_calories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 千卡"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/diet_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_food_summary"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
