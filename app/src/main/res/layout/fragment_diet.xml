<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="32dp">

            <!-- 返回与日期导航控制条 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageButton
                    android:id="@+id/btn_prev_day"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/diet_primary"
                    android:contentDescription="前一天" />

                <TextView
                    android:id="@+id/tv_selected_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="今日"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:padding="8dp"
                    android:background="?attr/selectableItemBackground" />

                <ImageButton
                    android:id="@+id/btn_next_day"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_next"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/diet_primary"
                    android:contentDescription="后一天" />
            </LinearLayout>

            <!-- 顶部英雄数据看板 (Hero Dashboard) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:outlineSpotShadowColor="#264E3F35"
                android:outlineAmbientShadowColor="#264E3F35"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_3d_diet"
                    android:padding="16dp">

                    <!-- 第一行：大数字 + 火焰图标 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:id="@+id/tv_total_calories"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0"
                            android:textSize="56sp"
                            android:textColor="@color/diet_primary"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_hero_diet"
                            android:contentDescription="饮食图标" />
                    </LinearLayout>

                    <!-- 第二行：单位描述 + 进度条 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_calories_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="千卡 · 今日已摄入"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progress_calories"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            app:trackCornerRadius="3dp"
                            app:indicatorColor="@color/diet_primary"
                            app:trackColor="@color/diet_track"
                            android:max="100"
                            android:progress="0"
                            android:layout_marginBottom="8dp" />

                        <!-- 宏量营养素进度条 (并排三段) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_diet_stats_sunken"
                            android:paddingVertical="12dp"
                            android:paddingHorizontal="12dp"
                            android:baselineAligned="false">

                            <!-- 蛋白质进度 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginEnd="4dp"
                                android:padding="0dp">

                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/progress_protein"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    app:trackCornerRadius="3dp"
                                    app:indicatorColor="@color/diet_protein_indicator"
                                    app:trackColor="@color/diet_protein_track"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tv_protein_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="蛋白质: 0/0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- 碳水进度 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginHorizontal="4dp"
                                android:padding="0dp">

                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/progress_carbs"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    app:trackCornerRadius="3dp"
                                    app:indicatorColor="@color/diet_carbs_indicator"
                                    app:trackColor="@color/diet_carbs_track"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tv_carbs_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="碳水: 0/0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- 脂肪进度 -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="4dp"
                                android:padding="0dp">

                                <com.google.android.material.progressindicator.LinearProgressIndicator
                                    android:id="@+id/progress_fat"
                                    android:layout_width="match_parent"
                                    android:layout_height="6dp"
                                    app:trackCornerRadius="3dp"
                                    app:indicatorColor="#FFA726"
                                    app:trackColor="#FFE0B2"
                                    android:max="100"
                                    android:progress="0"
                                    android:layout_marginBottom="4dp" />

                                <TextView
                                    android:id="@+id/tv_fat_status"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="脂肪: 0/0"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary"
                                    android:textStyle="bold" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 中部：餐点通栏列表 (垂直排列) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- 早餐 -->
                <include
                    android:id="@+id/card_breakfast"
                    layout="@layout/include_meal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp" />

                <!-- 午餐 -->
                <include
                    android:id="@+id/card_lunch"
                    layout="@layout/include_meal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp" />

                <!-- 晚餐 -->
                <include
                    android:id="@+id/card_dinner"
                    layout="@layout/include_meal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp" />

                <!-- 加餐 -->
                <include
                    android:id="@+id/card_snack"
                    layout="@layout/include_meal_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="6dp" />

            </LinearLayout>

            <!-- 底部：食物搜索栏 (内聚扫码与AI) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_food_wiki"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="24dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:outlineSpotShadowColor="#1A4E3F35"
                android:outlineAmbientShadowColor="#1A4E3F35">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card_3d_meal"
                    android:paddingVertical="12dp"
                    android:paddingHorizontal="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="@color/diet_primary"
                        android:layout_marginEnd="10dp"
                        android:contentDescription="搜索" />

                    <TextView
                        android:id="@+id/tv_search_placeholder"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="查询食物热量/营养素..."
                        android:textColor="@color/text_hint"
                        android:textSize="15sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ai_food_record"
                        style="@style/Widget.App.Button.Outlined.Diet"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:minHeight="48dp"
                        android:text="AI记录饮食"
                        android:textAllCaps="false"
                        android:textSize="12sp"
                        app:cornerRadius="20dp"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconPadding="4dp"
                        app:iconSize="16dp"
                        app:iconTint="@color/diet_primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 常用/历史食物快捷 Chip 容器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 常用食物快捷添加 (点按直接记录 1 份)"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cg_frequent_foods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleLine="true" />
            </LinearLayout>

            <!-- ⭐ 收藏食物 Chip 容器 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 收藏食物"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="16dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/cg_favorite_foods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    app:singleLine="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 废弃 FAB (设为 GONE) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="添加饮食记录"
        app:tint="@color/white"
        app:backgroundTint="@color/fitnessdiary_primary"
        android:visibility="gone" />

    <com.cz.fitnessdiary.ui.widget.FoodScanFlowView
        android:id="@+id/view_food_scan_flow"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />
</FrameLayout>
