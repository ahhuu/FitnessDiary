<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background"
    android:clipToPadding="false"
    android:paddingBottom="100dp"
    android:clipChildren="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:clipToPadding="false"
        android:clipChildren="false">

        <!-- 头部用户信息卡片 (3D 悬浮) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- 左侧：圆形头像 (3D下凹托盘，带纯白防锯齿描边) -->
                <FrameLayout
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:background="@drawable/bg_circle_sunken">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:scaleType="centerCrop"
                        android:clickable="true"
                        android:focusable="true"
                        app:strokeWidth="1.5dp"
                        app:strokeColor="#FFFFFF"
                        app:shapeAppearanceOverlay="@style/CircleImageView"
                        android:contentDescription="用户头像" />
                </FrameLayout>

                <!-- 中间：用户名 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="健身达人"
                        android:textSize="20sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />
                    
                    <!-- 动态等级 Badge -->
                    <TextView
                        android:id="@+id/tv_user_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Lv.0 新手"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- 右侧：设置按钮 (3D下凹底座) -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageButton
                        android:id="@+id/btn_settings_top"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:background="@android:color/transparent"
                        android:src="@drawable/ic_settings"
                        android:scaleType="fitCenter"
                        app:tint="@color/fitnessdiary_primary"
                        android:contentDescription="设置" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 核心数据 (2x2 Grid) 3D悬浮卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 第一行：体重 + 身高 (3D下凹凹槽) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- 体重 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_weight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="65.0"
                            android:textSize="32sp"
                            android:textColor="@color/fitnessdiary_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚖️ 体重 (kg)"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- 身高 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_height"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="170"
                            android:textSize="32sp"
                            android:textColor="@color/fitnessdiary_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📏 身高 (cm)"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第二行：BMI + BMR (3D下凹凹槽) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- BMI -->
                    <LinearLayout
                        android:id="@+id/layout_bmi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_bmi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="22.5"
                            android:textSize="32sp"
                            android:textColor="@color/color_success"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📊 BMI"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                    <!-- BMR (基础代谢) -->
                    <LinearLayout
                        android:id="@+id/layout_bmr"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="12dp">

                        <TextView
                            android:id="@+id/tv_bmr"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1650"
                            android:textSize="32sp"
                            android:textColor="@color/color_warning"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥 BMR (千卡)"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- 第三行：年龄 + 性别 (3D下凹凹槽，统一对齐) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- 年龄 -->
                    <LinearLayout
                        android:id="@+id/layout_age"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎂 年龄: "
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_age"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25 岁"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- 性别 -->
                    <LinearLayout
                        android:id="@+id/layout_gender"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_profile_data_sunken"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tv_gender_icon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👫 性别: "
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_gender"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="男"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 当前目标卡片 (3D 悬浮) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_goal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎯 当前目标"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_goal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="减脂"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 3D圆形编辑按钮底托 -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/text_secondary"
                        android:contentDescription="编辑目标" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Activity Level 卡片 (3D 悬浮) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_activity_level"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏋️ 活动水平"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:id="@+id/tv_activity_level"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="轻度活动 (1.375)"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 3D圆形编辑按钮底托 -->
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/text_secondary"
                        android:contentDescription="编辑活动水平" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 成就系统入口 (3D 悬浮) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_achievements"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- 物理小凹坑装载奖杯 -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_sunken">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="🏆"
                        android:textSize="18sp" />
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="成就勋章墙"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_achievement_summary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="已获得 0 枚"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <!-- 3D圆形指示箭头底座 -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_hint"
                        android:contentDescription="查看详情" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 数据周报入口 (3D 悬浮) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_data_report"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginBottom="8dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- 左侧图标 (3D下凹) -->
                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_analytics"
                        app:tint="@color/fitnessdiary_primary"
                        android:contentDescription="图标" />
                </FrameLayout>

                <!-- 中间文本 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="数据周报"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看本周训练与饮食分析"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <!-- 右侧箭头 (3D下凹) -->
                <FrameLayout
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_circle_sunken">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_hint"
                        android:contentDescription="查看详情" />
                </FrameLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ════════════════════════════════════════════
             智能推送卡片（可展开式配置面板）
             ════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_smart_reminder"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="24dp"
            app:cardElevation="3dp"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp"
            android:outlineSpotShadowColor="#1A4E483F"
            android:outlineAmbientShadowColor="#1A4E483F">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_3d_profile"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── 顶部总控行 ── -->
                <LinearLayout
                    android:id="@+id/layout_smart_header"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <!-- 左侧图标 (3D下凹) -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_sunken">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_hero_fire"
                            app:tint="@color/fitnessdiary_primary"
                            android:contentDescription="智能推送图标" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="智能推送"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="点击展开 · 独立配置每项提醒"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 总开关 -->
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switch_smart_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:trackColor="@color/selector_switch_track"
                        app:thumbColor="@color/selector_switch_thumb"
                        android:checked="false" />

                    <!-- 展开箭头 -->
                    <ImageView
                        android:id="@+id/iv_smart_expand"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/text_hint"
                        android:rotation="90"
                        android:contentDescription="展开详情" />
                </LinearLayout>

                <!-- ── 分割线 ── -->
                <View
                    android:id="@+id/divider_smart"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#15000000"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="4dp"
                    android:visibility="gone" />

                <!-- ── 子项容器（默认折叠） ── -->
                <LinearLayout
                    android:id="@+id/layout_smart_sub_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- 子项 1：早晨概要 -->
                    <LinearLayout
                        android:id="@+id/item_morning"
