<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="10dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2.5dp"
    app:cardBackgroundColor="@color/fitnessdiary_surface"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- 左侧拖拽图标手柄 -->
        <ImageView
            android:id="@+id/iv_drag_handle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/bg_drag_handle"
            app:tint="@color/text_secondary" />

        <!-- 3D 浮雕圆形图标底盘 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginStart="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/fitnessdiary_accent_container"
            app:strokeWidth="0dp">

            <ImageView
                android:id="@+id/iv_card_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_hero_water" />
        </com.google.android.material.card.MaterialCardView>

        <!-- 卡片标题 -->
        <TextView
            android:id="@+id/tv_card_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- 3D 拟物化 Switch 开关 -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_visibility"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:trackColor="@color/selector_switch_track"
            app:thumbColor="@color/selector_switch_thumb" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
