<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶部操作与年月栏 (完全重构为图2极简大气留白风格) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingHorizontal="20dp"
            android:layout_marginTop="8dp">

            <!-- 左上角：月份大字 + 年份小字垂直布局（可点击） -->
            <LinearLayout
                android:id="@+id/layout_month_selector"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/tv_calendar_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 月"
                    android:textColor="@color/text_primary"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false"
                    android:drawableEnd="@drawable/ic_expand_more"
                    android:drawablePadding="6dp"
                    app:drawableTint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_calendar_year"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="2026 年"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- 右上角：报表、计划管理、偏好设置 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- 报表/统计按钮 -->
                <ImageButton
                    android:id="@+id/btn_analytics"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_sunken"
                    android:src="@drawable/ic_analytics"
                    app:tint="@color/text_secondary"
                    android:contentDescription="报表统计"
                    android:padding="9dp" />

                <!-- 计划管理入口（哑铃图标） -->
                <ImageButton
                    android:id="@+id/btn_plan_manage"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_sunken"
                    android:src="@drawable/ic_nav_plan_outline"
                    app:tint="@color/text_secondary"
                    android:contentDescription="计划管理"
                    android:padding="9dp" />

                <!-- 动作库入口 -->
                <ImageButton
                    android:id="@+id/btn_exercise_library"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_circle_sunken"
                    android:src="@drawable/ic_book"
                    app:tint="@color/text_secondary"
                    android:contentDescription="动作库"
                    android:padding="9dp" />

                <!-- 偏好设置按钮 -->
                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_circle_sunken"
                    android:src="@drawable/ic_settings"
                    app:tint="@color/text_secondary"
                    android:contentDescription="显示设置"
                    android:padding="9dp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- 历史日记主面板 -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="100dp">

                <!-- 星期标头 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="一" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="二" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="三" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="四" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="五" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="六" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="日" android:textStyle="bold" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center" />
                </LinearLayout>

                <!-- 日历网格列表 (拉大高度，容纳图2多行胶囊) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_calendar_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="16dp" />

                <!-- 选中日期详情卡片 (奶油白风格) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_day_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/fitnessdiary_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="3dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/divider">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tv_detail_date_label"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="0dp"
                                android:text="6月30日 记录详情"
                                android:textColor="@color/text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 运动信息明细 -->
                        <TextView
                            android:id="@+id/tv_detail_sport_summary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏋️ 今日运动：无训练记录"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/tv_detail_sport_stats"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="运动消耗：0 kcal | 实际时长：0 分钟"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginBottom="12dp" />

                        <!-- 备注展示区域 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:id="@+id/tv_detail_note"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="12dp"
                                android:text="📝 暂无备注"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btn_edit_note"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="编辑备注"
                                android:textColor="@color/plan_blue_primary"
                                android:textSize="12sp"
                                android:insetTop="0dp"
                                android:insetBottom="0dp"
                                android:minHeight="0dp"
                                android:minWidth="0dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/divider"
                            android:layout_marginBottom="12dp" />

                        <!-- 锻炼指标汇总 -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🏋️ 锻炼容量"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tv_detail_volume"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 kg"
                                    android:textColor="@color/cat_water_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="📊 完成组数"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tv_detail_total_sets"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 组"
                                    android:textColor="@color/diet_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="⏱ 训练时长"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tv_detail_duration"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 分钟"
                                    android:textColor="@color/color_success"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
