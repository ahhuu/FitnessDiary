<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/nested_scroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="100dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 顶部日期与欢迎头部区域 -->
                <LinearLayout
                    android:id="@+id/header_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="24dp"
                    android:paddingBottom="12dp">

                    <!-- 今日健康状态面板卡座 (Header Card) -->
                    <FrameLayout
                        android:id="@+id/card_header_dashboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp">

                        <LinearLayout
                            android:id="@+id/date_text_area"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:clickable="true"
                            android:focusable="true">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tv_welcome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="你好，同学！"
                                    android:textColor="@color/text_primary"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_today_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="2026年3月5日 · 星期四"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <!-- AI 每日温馨寄语 -->
                                <TextView
                                    android:id="@+id/tv_header_tip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="越自律，越自由！"
                                    android:textColor="@color/fitnessdiary_primary"
                                    android:textSize="12sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- AI 快捷召唤徽章 (已隐藏) -->
                            <ImageButton
                                android:id="@+id/btn_ai_quick"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_circle_sunken"
                                android:src="@drawable/ic_brain"
                                app:tint="@color/ai_primary"
                                android:contentDescription="AI 助手"
                                android:padding="8dp"
                                android:visibility="gone" />

                            <!-- 精致评分舱圆盘 (从80dp等比放大到100dp) -->
                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/fl_total_circle"
                                android:layout_width="100dp"
                                android:layout_height="100dp"
                                android:clickable="true"
                                android:focusable="true"
                                app:cardCornerRadius="50dp"
                                app:cardElevation="4dp"
                                app:cardBackgroundColor="@android:color/transparent"
                                app:strokeWidth="0dp"
                                android:outlineSpotShadowColor="#264E483F"
                                android:outlineAmbientShadowColor="#264E483F"
                                android:foreground="?attr/selectableItemBackgroundBorderless">

                                <FrameLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="@drawable/bg_total_score_disc">

                                    <!-- 3D 渐变圆形进度轨道 (从70dp放大到90dp) -->
                                    <com.cz.fitnessdiary.ui.widget.GradientCircularProgressView
                                        android:id="@+id/progress_total_circle"
                                        android:layout_width="90dp"
                                        android:layout_height="90dp"
                                        android:layout_gravity="center" />

                                    <!-- 内层凸起小圆盘 (从60dp放大到78dp) -->
                                    <FrameLayout
                                        android:layout_width="78dp"
                                        android:layout_height="78dp"
                                        android:layout_gravity="center"
                                        android:background="@drawable/bg_score_inner_disc">

                                        <LinearLayout
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_gravity="center"
                                            android:gravity="center"
                                            android:orientation="vertical">

                                            <TextView
                                                android:id="@+id/tv_progress_percent"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:text="65%"
                                                android:textColor="#766D60"
                                                android:textSize="22sp"
                                                android:fontFamily="sans-serif-medium"
                                                android:textStyle="bold" />

                                            <TextView
                                                android:id="@+id/tv_total_label"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_marginTop="1dp"
                                                android:text="今日总览"
                                                android:textColor="#9C9283"
                                                android:textSize="10sp" />
                                        </LinearLayout>
                                    </FrameLayout>
                                </FrameLayout>
                            </com.google.android.material.card.MaterialCardView>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- 下拉展开日期选择器 -->
                    <LinearLayout
                        android:id="@+id/ll_date_selector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_date_nav"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:orientation="horizontal"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_back_to_today"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="center_horizontal"
                            android:paddingHorizontal="12dp"
                            android:text="回到今天"
                            android:textSize="12sp"
                            android:visibility="gone"
                            app:cornerRadius="18dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cards_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingBottom="20dp">

                    <!-- 组间休息计时器卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_rest_timer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/fitnessdiary_surface"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#1A4E483F">

                        <include layout="@layout/fragment_rest_timer" />
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 今日任务卡片区域 (已隐藏，移至FAB) -->
                    <LinearLayout
                        android:id="@+id/layout_daily_missions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🎯 今日任务"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <!-- 药丸胶囊状态展示标签 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="8dp"
                                android:layout_marginBottom="6dp">

                                <TextView
                                    android:id="@+id/tv_mission_cal_balance"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="11sp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/diet_primary"
                                    android:background="@drawable/bg_tag_chip_cal"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/tv_mission_water"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="11sp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/cat_water_primary"
                                    android:background="@drawable/bg_tag_chip_water"
                                    android:layout_marginEnd="6dp" />

                                <TextView
                                    android:id="@+id/tv_mission_habit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="11sp"
                                    android:paddingHorizontal="10dp"
                                    android:paddingVertical="3dp"
                                    android:textStyle="bold"
                                    android:textColor="@color/cat_habit_primary"
                                    android:background="@drawable/bg_tag_chip_habit" />
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layout_mission_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:orientation="vertical" />
                        </LinearLayout>

                        <!-- 编辑胶囊按钮 -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_missions"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="28dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="8dp"
                            android:contentDescription="编辑任务"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:insetLeft="0dp"
                            android:insetRight="0dp"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:paddingHorizontal="10dp"
                            android:text="编辑"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp"
                            android:background="@drawable/bg_btn_edit_sunken"
                            app:backgroundTint="@null"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_edit"
                            app:iconPadding="3dp"
                            app:iconSize="12dp"
                            app:iconTint="@color/text_secondary"
                            app:strokeWidth="0dp" />
                    </LinearLayout>

                    <!-- v3: AI 日报 (已隐藏，移至FAB) -->
                    <include android:id="@+id/card_ai_briefing" layout="@layout/view_ai_daily_briefing" android:visibility="gone" />

                    <!-- 主卡片：运动记录 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_sport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#264E483F"
                        android:outlineAmbientShadowColor="#264E483F">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_3d_normal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:src="@drawable/ic_hero_dumbbell" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="运动记录"
                                    android:textColor="@color/text_primary"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <!-- 精致圆形快捷操作按钮 -->
                                <ImageButton
                                    android:id="@+id/btn_rest_timer_toggle"
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/bg_btn_circle_sunken"
                                    android:contentDescription="组间休息计时器"
                                    android:src="@android:drawable/ic_lock_idle_alarm"
                                    android:padding="8dp"
                                    android:scaleType="centerInside"
                                    app:tint="#2B3E50" />

                                <ImageButton
                                    android:id="@+id/btn_add_sport"
                                    android:layout_width="38dp"
                                    android:layout_height="38dp"
                                    android:background="@drawable/bg_btn_circle_sunken"
                                    android:contentDescription="添加运动"
                                    android:src="@drawable/ic_add"
                                    android:padding="8dp"
                                    android:scaleType="centerInside"
                                    app:tint="#2B3E50" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_sport_update"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="今日无训练计划，好好休息吧！"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tv_sport_weekly"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="本周已达成 1 天"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="14sp" />

                                <TextView
                                    android:id="@+id/tv_consecutive_days"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="连续打卡 0 天 🔥"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <!-- 水平渐变进度条 -->
                            <ProgressBar
                                android:id="@+id/progress_sport_today"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginTop="12dp"
                                android:progressDrawable="@drawable/gradient_progress_sport"
                                android:max="100"
                                android:progress="0" />

                            <!-- 今日消耗 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🔥"
                                    android:textSize="14sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text="今日消耗"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_sport_calories"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="end"
                                    android:text="0 千卡"
                                    android:textColor="#FF7043"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_sport_cal_breakdown"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text=""
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 主卡片：饮食记录 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_diet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#264E483F"
                        android:outlineAmbientShadowColor="#264E483F">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_3d_normal"
                            android:padding="20dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:src="@drawable/ic_hero_diet" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:layout_weight="1"
                                    android:text="饮食记录"
                                    android:textColor="@color/text_primary"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <!-- 大号千卡数值文字 -->
                                <TextView
                                    android:id="@+id/tv_diet_consumed"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 千卡"
                                    android:textColor="@color/diet_primary"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_diet_feedback"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="今日还可摄入 -- 千卡"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <!-- 水平渐变进度条 -->
                            <ProgressBar
                                android:id="@+id/progress_diet_today"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent"
                                android:layout_height="6dp"
                                android:layout_marginTop="12dp"
                                android:progressDrawable="@drawable/gradient_progress_diet"
                                android:max="100"
                                android:progress="0" />

                            <!-- 碳水 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🍚碳水"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_diet_carbs"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:layout_weight="1"
                                    android:text="0g"
                                    android:textColor="@color/text_primary"
                                    android:textSize="12sp" />

                                <ProgressBar
                                    android:id="@+id/progress_diet_carbs"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="80dp"
                                    android:layout_height="3dp"
                                    android:progressDrawable="@drawable/gradient_progress_carbs"
                                    android:max="100"
                                    android:progress="0" />
                            </LinearLayout>

                            <!-- 蛋白质 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🥩蛋白质"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />

                                <TextView
                                    android:id="@+id/tv_diet_protein"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="6dp"
                                    android:layout_weight="1"
                                    android:text="0g"
                                    android:textColor="@color/text_primary"
                                    android:textSize="12sp" />

                                <ProgressBar
                                    android:id="@+id/progress_diet_protein"
                                    style="?android:attr/progressBarStyleHorizontal"
                                    android:layout_width="80dp"
                                    android:layout_height="3dp"
                                    android:progressDrawable="@drawable/gradient_progress_protein"
                                    android:max="100"
                                    android:progress="0" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 二维小打卡卡片网格容器 -->
                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/grid_cards"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="2"
                        app:useDefaultMargins="false"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone" />

                    <FrameLayout
                        android:id="@+id/shell_card_water"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_water" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_sleep"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_sleep" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_habit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_habit" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_medication"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_medication" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_weight" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_measurement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_measure" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_bowel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_bowel" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_menstrual"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_menstrual" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_step"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_step" />
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/shell_card_mood"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">
                        <include layout="@layout/view_home_card_mood" />
                    </FrameLayout>

                    <!-- 21天挑战进度卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_challenge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="3dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#1A4E483F">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:background="@drawable/bg_card_3d_challenge"
                            android:padding="14dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tv_challenge_emoji"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🔥"
                                android:textSize="26sp" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="10dp">

                                <TextView
                                    android:id="@+id/tv_challenge_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="减脂冲刺"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tv_challenge_progress"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="第 1/21 天"
                                    android:textColor="#3D7D4C"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tv_challenge_fails"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="失败0/3"
                                android:textColor="#B85151"
                                android:textSize="11sp"
                                android:layout_marginEnd="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 底部分享、挑战日历等操作按键 (已隐藏，移至FAB) -->
                    <LinearLayout
                        android:id="@+id/layout_bottom_actions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="32dp"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_challenge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="21天挑战"
                            android:textColor="@color/text_secondary"
                            style="@style/Widget.Material3.Button.TextButton"
                            app:icon="@drawable/ic_hero_fire"
                            app:iconTint="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_heatmap"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="打卡日历"
                            android:textColor="@color/text_secondary"
                            style="@style/Widget.Material3.Button.TextButton"
                            app:icon="@drawable/ic_hero_calendar"
                            app:iconTint="@color/text_secondary" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_edit_home_cards"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="管理卡片"
                            android:textColor="@color/text_secondary"
                            style="@style/Widget.Material3.Button.TextButton"
                            app:icon="@drawable/ic_edit"
                            app:iconTint="@color/text_secondary" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
