<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/fitnessdiary_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- 拖拽把手 -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:background="@color/divider" />

        <!-- ═══════════════════════════════════════════════════
             面板一：进行中的挑战
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 顶部信息卡 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_active_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/panel_translucent_bg"
                app:strokeWidth="1dp"
                app:strokeColor="#10000000">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <!-- Emoji 圆形底座 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_active_emoji_bg"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        app:cardBackgroundColor="#FFF9C4"
                        android:layout_marginEnd="16dp">
                        <TextView
                            android:id="@+id/tv_active_emoji"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text="🔥"
                            android:textSize="30sp" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_active_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="减脂冲刺"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_active_desc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="21天热量不超标"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:layout_marginTop="3dp"
                            android:maxLines="2" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 进度条区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_active_progress_txt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="第 1 / 21 天"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_active_fail_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="失败 0 / 3 次"
                        android:textColor="#EF5350"
                        android:textSize="12sp"
                        android:background="@drawable/bg_circle_red"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="3dp" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progress_active_challenge"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:max="21"
                    android:progress="1"
                    android:progressDrawable="@drawable/progress_rounded_success" />
            </LinearLayout>

            <!-- 打卡轨迹标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="8dp"
                android:text="21天打卡轨迹"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- 21天打卡方格网格 -->
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_active_tracking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="20dp"
                app:columnCount="7"
                app:rowCount="3" />

            <!-- 手动打卡按钮 / 自动联动提示 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_active_checkin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:text="今日打卡"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:visibility="gone"
                app:backgroundTint="#43A047"
                app:cornerRadius="26dp"
                app:icon="@drawable/ic_nav_checkin_filled"
                app:iconGravity="textStart"
                app:iconTint="@android:color/white" />

            <TextView
                android:id="@+id/tv_active_auto_hint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_rounded_gray"
                android:gravity="center"
                android:padding="12dp"
                android:text="💡 已绑定数据卡片，完成当日目标后自动计入"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:visibility="visible" />

            <!-- 放弃挑战 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_active_abandon"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:text="放弃挑战"
                android:textColor="#B0BEC5"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             面板二：挑战选择库
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 标题行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="选择挑战"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21天蜕变计划"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 分类 Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_all"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全部"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_diet"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥑 饮食" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_sport"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏃 运动" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_sleep"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 作息" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_custom"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ 我的" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- 挑战卡片列表 -->
            <LinearLayout
                android:id="@+id/layout_picker_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             面板三：创建自定义挑战
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_create"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:visibility="gone">

            <!-- 标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✏️  新建自定义挑战"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 挑战名称 -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="挑战名称（如：每天不喝甜饮料）">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_create_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:maxLength="20" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 规则说明 -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="规则说明（如：控制糖分摄入，不喝含糖饮料）">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_create_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:maxLength="50" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 容错天数 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="最多允许失败"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_create_fails_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 天"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seek_create_fails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5"
                android:progress="3"
                android:layout_marginBottom="18dp" />

            <!-- 打卡校验机制 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="打卡校验方式"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_bindings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="18dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_none"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✍️ 手动打卡"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_water"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 饮水达标" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_fat"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 热量不超标" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_sport"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 每日运动" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_sleep"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 23点早睡" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_step"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃 每日万步" />

            </com.google.android.material.chip.ChipGroup>

            <!-- 选择图标 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择挑战图标"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_emoji_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="6"
                android:layout_marginBottom="24dp" />

            <!-- 底部按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_cancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="取消"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建并开始"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#43A047"
                    app:cornerRadius="20dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
