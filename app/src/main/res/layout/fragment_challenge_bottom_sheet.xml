<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- 拖拽把手 -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="4dp"
            android:background="@color/divider" />

        <!-- ═══════════════════════════════════════════════════
             面板一：进行中的挑战
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_active"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             面板二：挑战选择库
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_picker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- 标题行 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="选择挑战"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21天蜕变计划"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- 分类 Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="16dp"
                android:layout_marginBottom="12dp">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_categories"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_all"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全部"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_diet"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🥑 饮食" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_sport"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏃 运动" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_sleep"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌙 作息" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_mind"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="😌 身心" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cat_custom"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✏️ 我的" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- 挑战卡片列表 -->
            <LinearLayout
                android:id="@+id/layout_picker_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════
             面板三：创建自定义挑战
             ═══════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_create"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:visibility="gone">

            <!-- 标题 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✏️  新建自定义挑战"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 挑战名称 -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="挑战名称（如：每天不喝甜饮料）">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_create_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:maxLength="20" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 规则说明 -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:hint="规则说明（如：控制糖分摄入，不喝含糖饮料）">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_create_desc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textSize="14sp"
                    android:maxLength="50" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- 所属分类 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="所属分类"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="16dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_diet_create"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥑 饮食" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_sport_create"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃 运动" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_sleep_create"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 作息" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_mind_create"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😌 身心" />
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cat_my_create"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✏️ 综合"
                    android:checked="true" />
            </com.google.android.material.chip.ChipGroup>

            <!-- 挑战周期 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="挑战总天数"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_create_duration_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21 天"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seek_create_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="93"
                android:progress="14"
                android:layout_marginBottom="16dp" />

            <!-- 目标打卡次数 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="目标打卡次数"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_create_target_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21 次"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seek_create_target"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="21"
                android:progress="21"
                android:layout_marginBottom="16dp" />

            <!-- 请假条数量 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="可用请假条"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_create_freeze_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2 张"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seek_create_freeze"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="5"
                android:progress="2"
                android:layout_marginBottom="18dp" />

            <!-- 最大允许无故断卡 (Max Fails) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="最大允许无故断卡"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_create_max_fails_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 次"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
            <SeekBar
                android:id="@+id/seek_create_max_fails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="3"
                android:layout_marginBottom="18dp" />

            <!-- 定时提醒 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_rounded_gray"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="打卡提醒"
                        android:textColor="@color/text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_create_reminder_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未开启"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_create_reminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- 打卡校验机制 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="打卡校验方式"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_bindings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                android:layout_marginBottom="18dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_none"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✍️ 手动打卡"
                    android:checked="true" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_water"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 饮水达标" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_fat"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 热量不超标" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_sport"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💪 每日运动" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_sleep"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌙 23点早睡" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_step"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏃 每日万步" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_mood"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😌 情绪" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_weight"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚖️ 称重" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_muscle_diet"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥩 增肌饮食" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_bind_medication"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💊 规律服药" />

            </com.google.android.material.chip.ChipGroup>

            <!-- 选择图标 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="选择挑战图标"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/grid_emoji_selector"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="6"
                android:layout_marginBottom="24dp" />

            <!-- 底部按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:layout_marginBottom="8dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_cancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="取消"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_create_submit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="创建并开始"
                    android:textColor="@android:color/white"
                    app:backgroundTint="#43A047"
                    app:cornerRadius="20dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
    </FrameLayout>
</androidx.core.widget.NestedScrollView>

<!-- Lottie confetti overlay for manual check-in -->
<com.airbnb.lottie.LottieAnimationView
    android:id="@+id/lottie_confetti"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:layout_gravity="center|bottom"
    android:layout_marginBottom="100dp"
    android:elevation="10dp"
    app:lottie_rawRes="@raw/confetti"
    app:lottie_autoPlay="false"
    app:lottie_loop="false"
    android:visibility="gone" />

</FrameLayout>
