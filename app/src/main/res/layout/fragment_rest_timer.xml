<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_home_header">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_timer_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="组间休息"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tv_timer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60"
            android:textColor="@color/fitnessdiary_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_timer_reset"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            app:icon="@android:drawable/ic_menu_revert"
            app:iconSize="24dp"
            app:iconTint="@color/text_secondary"
            app:backgroundTint="#1A000000"
            app:cornerRadius="22dp"
            app:iconGravity="textStart"
            android:contentDescription="重置" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_timer_action"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            app:icon="@android:drawable/ic_media_play"
            app:iconSize="24dp"
            app:iconTint="@color/white"
            app:backgroundTint="@color/fitnessdiary_primary"
            app:cornerRadius="22dp"
            app:iconGravity="textStart" />
    </LinearLayout>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_timer_presets"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        app:checkedChip="@id/chip_60s">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_30s"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="30s"
            android:textSize="11sp"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_60s"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="60s"
            android:textSize="11sp"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_90s"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="90s"
            android:textSize="11sp"
            style="@style/Widget.Material3.Chip.Filter" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_120s"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="120s"
            android:textSize="11sp"
            style="@style/Widget.Material3.Chip.Filter" />
    </com.google.android.material.chip.ChipGroup>
</LinearLayout>
