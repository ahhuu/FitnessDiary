<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fitnessdiary_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 顶栏返回区域 (固定) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/text_primary"
                android:contentDescription="返回" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="计划管理"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 顶部分类 Tab (固定) -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/plan_blue_primary"
            app:tabSelectedTextColor="@color/plan_blue_primary"
            app:tabTextColor="@color/text_secondary"
            app:tabIndicatorHeight="3dp"
            app:tabRippleColor="@android:color/transparent" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- 当前计划视图 (原版详情页结果页) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_current_plan"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="96dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/layout_hero_stats"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        app:cardBackgroundColor="@android:color/transparent"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#262E3B4E"
                        android:outlineAmbientShadowColor="#262E3B4E">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_card_3d_plan"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tv_active_plan_label"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="当前活跃计划 (基础)"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="13sp" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:gravity="bottom"
                                        android:orientation="horizontal">

                                        <TextView
                                            android:id="@+id/tv_plan_count"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="0"
                                            android:textColor="@color/plan_blue_primary"
                                            android:textSize="38sp"
                                            android:textStyle="bold" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="6dp"
                                            android:layout_marginBottom="8dp"
                                            android:text="项"
                                            android:textColor="@color/text_secondary"
                                            android:textSize="14sp" />
                                    </LinearLayout>
                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/iv_hero_icon"
                                    android:layout_width="54dp"
                                    android:layout_height="54dp"
                                    android:alpha="1"
                                    android:contentDescription="训练图标"
                                    android:src="@drawable/ic_hero_dumbbell" />
                            </LinearLayout>

                            <!-- 仪表槽下凹数据面板区 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:orientation="horizontal"
                                android:background="@drawable/bg_plan_stats_sunken"
                                android:paddingVertical="10dp"
                                android:paddingHorizontal="14dp"
                                android:baselineAligned="false">

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:padding="0dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="本周频次"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                    <TextView
                                        android:id="@+id/tv_weekly_frequency"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 次/周"
                                        android:textColor="@color/plan_blue_primary"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <Space
                                    android:layout_width="12dp"
                                    android:layout_height="1dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:padding="0dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="覆盖部位"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                    <TextView
                                        android:id="@+id/tv_body_part_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 类"
                                        android:textColor="@color/plan_blue_primary"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>

                                <Space
                                    android:layout_width="12dp"
                                    android:layout_height="1dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:padding="0dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="动作总数"
                                        android:textColor="@color/text_secondary"
                                        android:textSize="11sp" />

                                    <TextView
                                        android:id="@+id/tv_action_count"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0 个"
                                        android:textColor="@color/plan_blue_primary"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />
                                </LinearLayout>
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:text="目标部位"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp" />

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/cg_categories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                app:chipSpacingHorizontal="6dp"
                                app:chipSpacingVertical="6dp" />

                            <TextView
                                android:id="@+id/tv_covered_categories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="暂无目标"
                                android:textColor="@color/text_hint"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_plans"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false"
                        android:paddingBottom="8dp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/layout_empty_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="72dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="96dp"
                            android:layout_height="96dp"
                            android:alpha="0.45"
                            android:src="@drawable/ic_hero_dumbbell"
                            app:tint="@color/fitnessdiary_surface_variant" />

                        <TextView
                            android:id="@+id/tv_empty_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="还没有训练计划"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_empty_subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="导入模板计划或使用 AI 制定属于你的计划吧！"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_template_import"
                            style="@style/Widget.App.Button.Filled.Plan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:text="前往探索计划库"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- 探索计划库视图 (重塑后的选择页面) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_explore_library"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="96dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- AI 智能制定大卡片 -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_ai_wizard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="4dp"
                        app:strokeWidth="0dp"
                        android:outlineSpotShadowColor="#262E3B4E"
                        android:outlineAmbientShadowColor="#262E3B4E">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_3d_plan"
                            android:orientation="horizontal"
                            android:padding="20dp"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="AI 制定训练计划"
                                    android:textColor="@color/plan_blue_primary"
                                    android:textSize="20sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="智能匹配场景与目标，支持 AI 在线推荐与扩充动作"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="12sp" />
                            </LinearLayout>

                            <ImageView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:layout_marginStart="12dp"
                                android:src="@drawable/ic_brain"
                                app:tint="@color/ai_primary" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- 分类 Filter Chips 过滤器 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="模板分类:"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cg_explore_filters"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_explore_all"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="全部"
                                android:checked="true" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_explore_bulking"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="增肌" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_explore_cutting"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="减脂" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_explore_shaping"
                                style="@style/Widget.MaterialComponents.Chip.Choice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="塑形" />
                        </com.google.android.material.chip.ChipGroup>
                    </LinearLayout>

                    <!-- 基础训练计划 (新手) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="新手入门计划 (基础级)"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_basic_templates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />

                    <!-- 进阶训练计划 (中高级) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:text="经典进阶计划 (中高级)"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_advanced_templates"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:clipToPadding="false"
                        android:nestedScrollingEnabled="false" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <!-- 个人计划列表视图 (全新 Tab 2) -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/scroll_personal_plans"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="96dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- 空状态提示 (当没有个人计划时显示) -->
                    <LinearLayout
                        android:id="@+id/layout_personal_empty"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:paddingVertical="80dp"
                        android:visibility="visible">

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_hero_dumbbell"
                            app:tint="@color/plan_blue_stroke" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:text="暂无个人计划模板"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="点击右下角“+”或者在探索库中导入计划吧！"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- 合并计划按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_merge_plans"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="4dp"
                        android:text="📋 合并计划"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        android:visibility="gone" />

                    <!-- 负重管理按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_weight_manager"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginBottom="8dp"
                        android:text="⚖️ 负重管理"
                        android:textSize="13sp"
                        app:cornerRadius="12dp"
                        android:visibility="gone" />

                    <!-- 个人计划卡片列表 -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_personal_plans"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone" />
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </FrameLayout>

    </LinearLayout>

    <!-- 右下角悬浮添加按钮 -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add_plan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="92dp"
        android:contentDescription="@string/plan_add"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/plan_blue_container"
        app:elevation="4dp"
        app:tint="@color/plan_blue_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
