<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginVertical="6dp">

    <TextView
        android:id="@+id/tv_rank_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="1. 早起"
        android:textColor="@color/text_primary"
        android:textSize="13sp" />

    <ProgressBar
        android:id="@+id/progress_rank"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="120dp"
        android:layout_height="8dp"
        android:layout_marginHorizontal="12dp"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/cat_habit_primary"
        android:progressBackgroundTint="@color/divider" />

    <TextView
        android:id="@+id/tv_rank_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12 次"
        android:textColor="@color/cat_habit_primary"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>
