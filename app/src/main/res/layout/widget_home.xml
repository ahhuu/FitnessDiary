<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Date + streak -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今日概览"
            android:textColor="#004D40"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="连续0天"
            android:textColor="#00695C"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Content row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Diet -->
        <LinearLayout
            android:id="@+id/ll_widget_diet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/progress_widget_diet"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:max="100"
                    android:progress="0"
                    android:indeterminate="false"
                    android:progressDrawable="@drawable/widget_ring_diet" />

                <TextView
                    android:id="@+id/tv_widget_diet_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="--"
                    android:textColor="#E87328"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="饮食 千卡"
                android:textColor="#757575"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Water -->
        <LinearLayout
            android:id="@+id/ll_widget_water"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp">

                <ProgressBar
                    android:id="@+id/progress_widget_water"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:max="100"
                    android:progress="0"
                    android:indeterminate="false"
                    android:progressDrawable="@drawable/widget_ring_water" />

                <TextView
                    android:id="@+id/tv_widget_water_val"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="--"
                    android:textColor="#007BFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="饮水 ml"
                android:textColor="#757575"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Sport -->
        <LinearLayout
            android:id="@+id/ll_widget_sport"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_widget_sport_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#1976D2"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="运动"
                android:textColor="#757575"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Sleep -->
        <LinearLayout
            android:id="@+id/ll_widget_sleep"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_widget_sleep_val"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#673AB7"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="睡眠"
                android:textColor="#757575"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
