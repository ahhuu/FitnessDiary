<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 顶部信息卡 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_active_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/fitnessdiary_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="22dp"
            android:gravity="center_vertical">

            <!-- Emoji 圆形底座 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_active_emoji_bg"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFF9C4"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/tv_active_emoji"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="🔥"
                    android:textSize="30sp" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:id="@+id/tv_active_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="减脂冲刺"
                        android:textColor="@color/text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tv_active_streak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="🔥 连击 0 天"
                        android:textColor="#FF9800"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_active_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="21天热量不超标"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="3dp"
                    android:maxLines="2" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 进度条区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tv_active_progress_txt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="第 1 / 21 天"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_active_fail_summary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="失败 0 / 3 次"
                android:textColor="#C62828"
                android:textSize="12sp"
                android:background="@drawable/bg_rounded_light_red"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_active_challenge"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="12dp"
            android:max="21"
            android:progress="1"
            android:layout_marginTop="4dp"
            android:progressDrawable="@drawable/progress_rounded_success" />
    </LinearLayout>

    <!-- 打卡轨迹标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:text="21天打卡轨迹"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- 21天打卡方格网格 -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/fitnessdiary_surface"
        app:strokeWidth="1dp"
        app:strokeColor="#08000000">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/grid_active_tracking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:paddingVertical="16dp"
            android:paddingHorizontal="8dp"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false" />
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_active_checkin"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="今日打卡"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:backgroundTint="#43A047"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_nav_checkin_filled"
            app:iconGravity="textStart"
            app:iconTint="@android:color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_active_freeze"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:text="❄️ 请假 (2)"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:visibility="gone"
            app:backgroundTint="#E3F2FD"
            app:cornerRadius="26dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_active_auto_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_rounded_gray"
        android:gravity="center"
        android:padding="12dp"
        android:text="💡 已绑定数据卡片，完成当日目标后自动计入"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="visible" />

    <!-- 放弃挑战 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_active_abandon"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:text="放弃挑战"
        android:textColor="#B0BEC5"
        android:textSize="12sp" />

</LinearLayout>
