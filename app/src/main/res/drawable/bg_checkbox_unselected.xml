<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 下层：右下亮色反光线 -->
    <item android:left="0.8dp" android:top="0.8dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
    <!-- 中层：左上内阴影线 -->
    <item android:left="0dp" android:top="0dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp"/>
            <solid android:color="#C6BEB5"/>
        </shape>
    </item>
    <!-- 表层：下凹区域填充底色 -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="5dp"/>
            <solid android:color="#EFECE6"/>
        </shape>
    </item>
</layer-list>
