<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：3D 浮雕深层阴影面，偏右下偏移 2dp -->
    <item android:left="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <solid android:color="#1A4E483F" />
        </shape>
    </item>

    <!-- 中间层：左上角斜向漏出的白色反射高光线 -->
    <item android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- 最表层：主面板，使用斜向 315 度受光的奶油渐变 -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="100dp" />
            <gradient
                android:angle="315"
                android:startColor="#FAF9F6"
                android:endColor="#EDE8DC"
                android:type="linear" />
        </shape>
    </item>
</layer-list>
