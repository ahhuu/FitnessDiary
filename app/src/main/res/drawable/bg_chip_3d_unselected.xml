<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下角漏出 1.2dp 阴影线 -->
    <item 
        android:left="1.2dp" 
        android:top="1.2dp" 
        android:right="0dp" 
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#E6E0D3"/>
        </shape>
    </item>

    <!-- 中间层：左上角漏出 1.2dp 纯白色高光线 -->
    <item 
        android:left="0dp" 
        android:top="0dp" 
        android:right="1.2dp" 
        android:bottom="1.2dp">
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：主体渐变 -->
    <item 
        android:left="1.2dp" 
        android:top="1.2dp" 
        android:right="1.2dp" 
        android:bottom="1.2dp">
        <shape android:shape="rectangle">
            <corners android:radius="10.5dp"/>
            <gradient
                android:startColor="#FAF9F6"
                android:endColor="#EDE8DC"
                android:angle="315"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
