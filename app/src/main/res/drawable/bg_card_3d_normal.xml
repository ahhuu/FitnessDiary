<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下角漏出 1dp 暖灰褐色描边线（模拟右下投影） -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#DFCBBF"/>
        </shape>
    </item>

    <!-- 中间层：左上角漏出 1dp 纯白色描边线（模拟左上反光高光线） -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：卡片主体，圆角 27dp，自带细微的 3D 斜向曲面光泽渐变 -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="26.5dp"/>
            <gradient
                android:startColor="#FFFFFF"
                android:endColor="#FAF8F3"
                android:angle="315"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
