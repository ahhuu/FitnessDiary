<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 右下暗色阴影 -->
    <item android:left="1dp" android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#1A000000" />
        </shape>
    </item>
    <!-- 左上亮白色高光 -->
    <item android:right="0.6dp" android:bottom="0.6dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <solid android:color="#60FFFFFF" />
        </shape>
    </item>
    <!-- 主体渐变面 -->
    <item android:left="0.6dp" android:top="0.6dp" android:right="0.6dp" android:bottom="0.6dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <gradient
                android:angle="315"
                android:startColor="#CFE3CC"
                android:endColor="#BAD3B6"
                android:type="linear" />
        </shape>
    </item>
    <!-- 上表面微反光 -->
    <item android:left="1.5dp" android:top="0.6dp" android:right="1.5dp" android:bottom="9dp">
        <shape android:shape="rectangle">
            <solid android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
