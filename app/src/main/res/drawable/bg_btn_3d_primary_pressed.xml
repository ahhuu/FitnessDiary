<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：左上深色内阴影 -->
    <item
        android:left="0dp"
        android:top="0dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#211E1A"/>
        </shape>
    </item>

    <!-- 中间层：右下高亮反光 -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#20FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：按下后的深凹陷底色 -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="26.5dp"/>
            <solid android:color="#2D2924"/>
        </shape>
    </item>
</layer-list>
