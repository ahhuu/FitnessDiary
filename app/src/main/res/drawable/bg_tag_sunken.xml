<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 下凹阴影面 -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#0D000000" />
        </shape>
    </item>
    <!-- 右下高光面 -->
    <item android:left="0.8dp" android:top="0.8dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- 主体填充底色 (极清淡的蓝色凹槽，对应计划主题) -->
    <item android:left="0.8dp" android:top="0.8dp" android:right="0.8dp" android:bottom="0.8dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#EAF1F8" />
        </shape>
    </item>
</layer-list>
