<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：模拟左上角阴影面（偏左上漏出，用于形成内凹陷阴影） -->
    <item 
        android:left="0dp" 
        android:top="0dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#DFD8CE"/>
        </shape>
    </item>

    <!-- 中间层：模拟右下角反光白高光（偏右下漏出） -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="0dp" 
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：内凹槽底色，略微比页面背景色深，呈温润奶油凹陷色 -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="12.5dp"/>
            <solid android:color="#F4F1E9"/>
        </shape>
    </item>
</layer-list>
