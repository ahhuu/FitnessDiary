<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下角深色阴影 -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="0dp" 
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#211E1A"/>
        </shape>
    </item>

    <!-- 中间层：左上角半透明白色高光 -->
    <item 
        android:left="0dp" 
        android:top="0dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <solid android:color="#40FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：按钮主体，带 3D 渐变 -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="26.5dp"/>
            <gradient
                android:startColor="#4A443B"
                android:endColor="#332F29"
                android:angle="315"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
