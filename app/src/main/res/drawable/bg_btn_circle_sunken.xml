<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 下层：右下亮色反光线 -->
    <item android:left="1dp" android:top="1dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
    <!-- 中层：左上暗色内阴影线 -->
    <item android:left="0dp" android:top="0dp" android:right="1.5dp" android:bottom="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#C6BEB5"/>
        </shape>
    </item>
    <!-- 表层：下凹区域填充底色 -->
    <item android:left="1.5dp" android:top="1.5dp" android:right="1.5dp" android:bottom="1.5dp">
        <shape android:shape="oval">
            <solid android:color="#ECE8DF"/>
        </shape>
    </item>
</layer-list>
