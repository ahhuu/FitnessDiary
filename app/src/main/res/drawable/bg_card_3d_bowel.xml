<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下角漏出 1.5dp 阴影线 -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="0dp" 
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="#DFD7D5"/>
        </shape>
    </item>

    <!-- 中间层：左上角漏出 1.5dp 纯白色高光线 -->
    <item 
        android:left="0dp" 
        android:top="0dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- 最表层：卡片主体，自带便便灰褐色相斜向 3D 渐变 -->
    <item 
        android:left="1.5dp" 
        android:top="1.5dp" 
        android:right="1.5dp" 
        android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="22.5dp"/>
            <gradient
                android:startColor="#FAF6F5"
                android:endColor="#EDE2E0"
                android:angle="315"
                android:type="linear"/>
        </shape>
    </item>
</layer-list>
