<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 最底层：右下角漏出 1dp 纯白高光线，模拟凹槽下壁的反光 -->
    <item 
        android:left="1dp" 
        android:top="1dp" 
        android:right="0dp" 
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>

    <!-- 中间层：左上角漏出 1dp 阴影线，模拟凹槽上壁的阴影 -->
    <item 
        android:left="0dp" 
        android:top="0dp" 
        android:right="1dp" 
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp"/>
            <solid android:color="#B8C8D6"/>
        </shape>
    </item>

    <!-- 最内层：凹槽底面，填充略深一丁点的淡蓝灰色 -->
    <item 
        android:left="1dp" 
        android:top="1dp" 
        android:right="1dp" 
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="15dp"/>
            <solid android:color="#E2ECF5"/>
        </shape>
    </item>
</layer-list>
